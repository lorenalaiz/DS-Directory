le",{"cx":"9","cy":"7","r":"3"}],["path",{"d":"M2 21v-2a4 4 0 0 1 4-4h2a4 4 0 0 1 4 4v2"}],["circle",{"cx":"18","cy":"8","r":"2.5"}],["path",{"d":"M15.5 21v-1.5a3.5 3.5 0 0 1 3.5-3.5h1a3.5 3.5 0 0 1 3.5 3.5V21"}]],"\n        ",["DIV",{"class":"display"},"No families added yet"],"\n        ",["P",{},"Add your family to start connecting with others nearby."],"\n      "]],"\n  "],"\n\n  ",["DIV",{"id":"viewMarketplace","class":"view-panel","style":"display:none;"},"\n    ",["DIV",{"class":"toolbar"},"\n      ",["DIV",{"class":"search-box"},"\n        ",["svg",{"width":"16","height":"16","viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","stroke-width":"2"},["circle",{"cx":"11","cy":"11","r":"8"}],["line",{"x1":"21","y1":"21","x2":"16.65","y2":"16.65"}]],"\n        ",["INPUT",{"__playwright_value_":"","id":"searchInputMkt","type":"text","placeholder":"Search by item, category, or note...","autocomplete":"new-password","name":"search-marketplace"}],"\n      "],"\n      ",["SELECT",{"id":"filterTypeMkt"},"\n        ",["OPTION",{"__playwright_selected_":"true","value":""},"All listing types"],"\n        ",["OPTION",{"__playwright_selected_":"false","value":"Donate"},"Donate"],"\n        ",["OPTION",{"__playwright_selected_":"false","value":"Sell"},"Sell"],"\n        ",["OPTION",{"__playwright_selected_":"false","value":"Rent"},"Rent"],"\n        ",["OPTION",{"__playwright_selected_":"false","value":"Lend"},"Lend"],"\n      "],"\n      ",["DIV",{"class":"view-mode-toggle"},"\n        ",["BUTTON",{"class":"view-mode-btn active","data-section":"marketplace","data-mode":"cards"},"▦"],"\n        ",["BUTTON",{"class":"view-mode-btn","data-section":"marketplace","data-mode":"table"},"☰"],"\n      "],"\n      ",["BUTTON",{"class":"btn btn-primary","id":"addBtnMkt"},"+ Post a listing"],"\n    "],"\n\n    ",["DIV",{"class":"count-row","id":"countRowMkt"}],"\n    ",["DIV",{"id":"gridAreaMkt"},"\n      ",["DIV",{"class":"empty-state"},"\n        ",["svg",{"width":"44","height":"44","viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","stroke-width":"1.5"},["path",{"d":"M20 7h-3V6a4 4 0 0 0-8 0v1H6a1 1 0 0 0-1 1v11a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8a1 1 0 0 0-1-1z"}],["path",{"d":"M9 7V6a3 3 0 0 1 6 0v1"}]],"\n        ",["DIV",{"class":"display"},"Nothing posted yet"],"\n        ",["P",{},"Post something to donate, sell, or rent to the community."],"\n      "]],"\n  "],"\n\n  ",["DIV",{"id":"viewNdisguide","class":"view-panel","style":"display:none;"},"\n    ",["DIV",{"class":"ndis-guide-page"},"\n      ",["P",{},["STRONG",{},"What is the NDIS?"],["BR"],"\n      The NDIS (National Disability Insurance Scheme) is Australia's national scheme that provides funding for people with disability to access the supports they need to live more independently and improve their quality of life. Depending on what's included in a person's plan, this funding can help pay for therapists, support workers, equipment, and other essential services."],"\n\n      ",["H4",{},"🩺 Therapists / Allied Health"],"\n      ",["P",{},["STRONG",{},"Occupational Therapist (OT)"],["BR"],"Helps a person gain more independence in daily life — from dressing and bathing to recommending equipment, home modifications, and assistive technology."],"\n      ",["P",{},["STRONG",{},"Physiotherapist"],["BR"],"Helps improve movement, strength, balance, and posture through hands-on treatment and personalised exercise programs. This can include neurological physiotherapy (e.g. cerebral palsy, stroke), musculoskeletal physiotherapy (muscle and joint issues), paediatric physiotherapy (supporting children's motor development), hydrotherapy (exercises in warm water), and respiratory physiotherapy (supporting breathing)."],"\n      ",["P",{},["STRONG",{},"Speech Pathologist"],["BR"],"Supports communication (speech, language) as well as swallowing/eating difficulties (dysphagia)."],"\n      ",["P",{},["STRONG",{},"Psychologist"],["BR"],"Supports emotional health, behaviour, and psychosocial wellbeing."],"\n      ",["P",{},["STRONG",{},"Music Therapist"],["BR"],"Uses music in a structured way to support communication, emotional regulation, and social skills."],"\n      ",["P",{},["STRONG",{},"Exercise Physiologist"],["BR"],"Creates personalised exercise programs to improve strength, mobility, and overall health — can also run hydrotherapy sessions."],"\n      ",["P",{},["STRONG",{},"Dietitian / Nutritionist"],["BR"],"Supports nutrition and dietary needs related to disability."],"\n      ",["P",{},["STRONG",{},"Audiologist"],["BR"],"Assesses and supports hearing issues that affect communication or safety."],"\n      ",["P",{},["STRONG",{},"Optometrist / Vision Specialist"],["BR"],"Assesses how vision impacts learning, mobility, and daily activities."],"\n\n      ",["H4",{},"🧩 Behavioural & Psychosocial Support"],"\n      ",["P",{},["STRONG",{},"Positive Behaviour Support (PBS) Specialist"],["BR"],"Develops strategies to support challenging behaviours in a positive, respectful way."],"\n      ",["P",{},["STRONG",{},"Psychosocial Recovery Coach"],["BR"],"Supports people with psychosocial disability (related to mental health) in their recovery and independence journey."],"\n      ",["P",{},["STRONG",{},"Allied Health Assistants"],["BR"],"Work under the supervision of a qualified professional (e.g. a physiotherapist), helping put the therapy plan into practice day to day."],"\n\n      ",["H4",{},"💉 Clinical Health Care"],"\n      ",["P",{},["STRONG",{},"Registered Nurse"],["BR"],"Needed for high-complexity health care, such as tracheostomy management or complex wound care."],"\n\n      ",["H4",{},"🤝 Coordination & Social Support"],"\n      ",["P",{},["STRONG",{},"Support Coordinator"],["BR"],"Helps a person understand and organise their NDIS plan, connecting them with the right services."],"\n      ",["P",{},["STRONG",{},"Social Worker"],["BR"],"Supports social, emotional, and practical day-to-day needs, connecting families with community resources."],"\n\n      ",["H4",{},"🏠 Direct Support Workers"],"\n      ",["P",{},["STRONG",{},"Support Worker"],["BR"],"Assists with daily activities — from personal care to participating in the community."],"\n    "],"\n  "],"\n\n  ",["DIV",{"id":"viewMessages","class":"view-panel","style":"display:none;"},"\n    ",["P",{"style":"font-size:12.5px;color:var(--muted);margin:0 0 16px;"},"Suggestions and bug reports sent through the \"Contact\" button — visible only to you."],"\n    ",["DIV",{"class":"view-mode-toggle","style":"margin-bottom:14px;"},"\n      ",["BUTTON",{"class":"view-mode-btn active","data-section":"messages","data-mode":"cards"},"▦ Cards"],"\n      ",["BUTTON",{"class":"view-mode-btn","data-section":"messages","data-mode":"table"},"☰ Table"],"\n    "],"\n    ",["DIV",{"class":"count-row","id":"countRowMsg"}],"\n    ",["DIV",{"id":"gridAreaMsg"},["DIV",{"class":"empty-state"},["DIV",{"class":"display"},"No messages yet"],["P",{},"Suggestions sent via \"Contact\" will show up here."]]],"\n  "],"\n\n  ",["DIV",{"id":"viewActivity","class":"view-panel","style":"display:none;"},"\n    ",["P",{"style":"font-size:12.5px;color:var(--muted);margin:0 0 16px;"},"What was added, edited, or deleted, and when — visible only to you. There's no login for regular users, so it doesn't show who made each change."],"\n    ",["DIV",{"class":"toolbar","style":"margin-bottom:14px;"},"\n      ",["DIV",{"class":"form-group","style":"margin-bottom:0;"},"\n        ",["LABEL",{"style":"margin-bottom:3px;"},"From"],"\n        ",["INPUT",{"__playwright_value_":"","type":"date","id":"activityFromDate"}],"\n      "],"\n      ",["DIV",{"class":"form-group","style":"margin-bottom:0;"},"\n        ",["LABEL",{"style":"margin-bottom:3px;"},"To"],"\n        ",["INPUT",{"__playwright_value_":"","type":"date","id":"activityToDate"}],"\n      "],"\n      ",["BUTTON",{"class":"btn btn-ghost","id":"activityClearDateBtn"},"Clear dates"],"\n    "],"\n    ",["DIV",{"class":"count-row","id":"countRowAct"},"46 of