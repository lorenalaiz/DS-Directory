{"type":"frame-snapshot","snapshot":{"callId":"call@8","snapshotName":"after@call@8","pageId":"page@ee9fcc7bff7e5e2468b62adba592a9ad","frameId":"frame@9c895f64f8cabc54315330d8c391bc40","frameUrl":"http://localhost:3000/","doctype":"html","html":["HTML",{"lang":"en"},["HEAD",{},["BASE",{"href":"http://localhost:3000/"}],"\n",["META",{"charset":"utf-8"}],"\n",["META",{"name":"viewport","content":"width=device-width, initial-scale=1.0"}],"\n",["TITLE",{},"DS Community Directory"],"\n",["LINK",{"rel":"manifest","href":"manifest.json"}],"\n",["LINK",{"rel":"icon","href":"icon-192.png","type":"image/png"}],"\n",["LINK",{"rel":"apple-touch-icon","href":"apple-touch-icon.png"}],"\n",["META",{"name":"theme-color","content":"#2E5FA3"}],"\n",["META",{"name":"apple-mobile-web-app-capable","content":"yes"}],"\n",["META",{"name":"apple-mobile-web-app-status-bar-style","content":"default"}],"\n",["META",{"name":"apple-mobile-web-app-title","content":"DS Network"}],"\n",["LINK",{"rel":"preconnect","href":"https://fonts.googleapis.com"}],"\n",["LINK",{"href":"https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;0,9..144,700;1,9..144,500&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@500&display=swap","rel":"stylesheet"}],"\n",["LINK",{"rel":"stylesheet","href":"https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.css"}],"\n","\n","\n","\n","\n","\n",["STYLE",{},"\n  :root{\n    --ink:#1F2A38;\n    --primary:#2E5FA3;\n    --primary-dark:#1F4373;\n    --primary-light:#E5EEF9;\n    --accent:#F4B942;\n    --accent-light:#FDF3DC;\n    --bg:#F7F8F5;\n    --card:#FFFFFF;\n    --muted:#7A8590;\n    --border:#DCE2E8;\n    --danger:#C1524A;\n  }\n  *{box-sizing:border-box;}\n  body{margin:0;background:var(--bg);color:var(--ink);font-family:'Inter',sans-serif;-webkit-font-smoothing:antialiased;}\n  h1,h2,h3,.display{font-family:'Fraunces',serif;}\n\n  .wrap{max-width:960px;margin:0 auto;padding:0 20px 80px;}\n  @media (min-width:1300px){\n    .wrap{max-width:1180px;}\n  }\n\n  header.top{\n    margin:0 0 28px;padding:46px 34px 40px;border-radius:0 0 28px 28px;\n    background:linear-gradient(120deg, #274C82 0%, #3E6FB8 60%, var(--primary) 100%);\n    position:relative;overflow:hidden;\n  }\n  .header-top-row{position:relative;z-index:1;}\n  .header-chromo-deco{\n    position:absolute;right:28px;top:60px;width:99px;height:auto;\n    opacity:0.92;pointer-events:none;z-index:0;\n  }\n  @media (max-width:900px){\n    .header-chromo-deco{display:none;}\n  }\n  header.top .eyebrow{\n    display:inline-block;font-family:'JetBrains Mono',monospace;\n    font-size:11px;letter-spacing:.12em;text-transform:uppercase;\n    color:var(--accent);font-weight:600;margin-bottom:16px;position:relative;\n    border:1px solid rgba(244,185,66,0.5);padding:5px 12px;border-radius:100px;\n  }\n  header.top h1{font-size:38px;font-weight:600;margin:0 0 6px;color:#fff;position:relative;display:flex;align-items:center;gap:12px;}\n  .header-title-underline{width:150px;height:3px;background:var(--accent);border-radius:2px;margin-bottom:14px;position:relative;}\n  header.top p{margin:0;color:rgba(255,255,255,0.88);font-size:14.5px;max-width:520px;line-height:1.6;position:relative;}\n\n  .view-tabs{display:flex;gap:8px;margin-bottom:20px;flex-wrap:wrap;row-gap:10px;}\n  .view-tab{\n    font-family:'Inter';font-weight:600;font-size:14px;padding:10px 18px;border-radius:100px;\n    border:1px solid var(--border);background:var(--card);color:var(--muted);cursor:pointer;\n    transition:all .15s ease;\n  }\n  .view-tab.active{background:var(--primary);color:#fff;border-color:var(--primary);box-shadow:0 2px 8px rgba(46,95,163,0.28);}\n  .view-tab.has-alert:not(.active){color:#B8452E;font-weight:700;border-color:#F0C4B8;}\n  .view-tab:not(.active):hover{border-color:var(--primary);color:var(--primary-dark);}\n  .tab-badge{\n    display:inline-flex;align-items:center;justify-content:center;\n    min-width:17px;height:17px;padding:0 4px;margin-left:5px;border-radius:100px;\n    background:#B8452E;color:#fff;font-size:10.5px;font-weight:700;line-height:1;\n  }\n  .view-tab.active .tab-badge{background:#fff;color:var(--primary);}\n\n  .view-mode-toggle{display:flex;gap:4px;background:var(--card);border:1px solid var(--border);border-radius:100px;padding:3px;margin-left:8px;}\n\n  .admin-dropdown{\n    display:none;position:absolute;top:calc(100% + 6px);right:0;z-index:60;\n    background:var(--card);border:1px solid var(--border);border-radius:14px;\n    box-shadow:0 10px 30px rgba(31,42,56,0.16);padding:8px;min-width:170px;flex-direction:column;gap:2px;\n  }\n  .admin-dropdown.open{display:flex;}\n  .admin-dropdown button{\n    background:none;border:none;text-align:left;padding:9px 12px;border-radius:8px;\n    font-family:'Inter';font-size:13.5px;font-weight:500;color:var(--ink);cursor:pointer;\n  }\n  .admin-dropdown button:hover{background:var(--primary-light);}\n  .admin-dropdown-divider{height:1px;background:var(--border);margin:4px 2px;}\n  .view-mode-btn{\n    background:none;border:none;padding:7px 13px;border-radius:100px;font-size:13px;font-weight:600;\n    color:var(--muted);cursor:pointer;display:flex;align-items:center;gap:5px;\n  }\n  .view-mode-btn.active{background:var(--primary);color:#fff;}\n  .table-wrap{overflow-x:auto;background:var(--card);border:1px solid var(--border);border-radius:14px;}\n  table.data-table{width:100%;border-collapse:collapse;font-size:13.5px;}\n  table.data-table th{\n    text-align:left;padding:11px 14px;background:var(--primary-light);color:var(--primary-dark);\n    font-size:11.5px;text-transform:uppercase;letter-spacing:.04em;font-weight:700;white-space:nowrap;\n  }\n  table.data-table td{padding:10px 14px;border-top:1px solid var(--border);vertical-align:top;}\n  table.data-table tbody tr:hover{background:var(--primary-light);}\n  table.data-table td.table-actions{white-space:nowrap;text-align:right;}\n  table.data-table td.table-actions button{margin-left:6px;}\n  .table-check{\n    display:inline-flex;align-items:center;justify-content:center;\n    width:22px;height:22px;border-radius:50%;background:#E4F1E4;color:#3D7A3D;\n    font-size:14px;font-weight:700;line-height:1;\n  }\n  .table-link-btn{\n    background:none;border:none;padding:0;font-family:'Inter';font-size:13.5px;\n    color:var(--primary-dark);font-weight:600;cursor:pointer;white-space:nowrap;\n  }\n  .table-link-btn:hover{text-decoration:underline;}\n\n  .toolbar{\n    display:flex;gap:10px;margin:0 0 20px;flex-wrap:wrap;align-items:center;\n    background:var(--card);padding:12px;border-radius:16px;border:1px solid var(--border);\n    box-shadow:0 2px 10px rgba(31,42,56,0.04);\n  }\n  .ndis-banner{\n    background:var(--primary-light);border:1px solid var(--border);border-radius:14px;\n    padding:14px 18px;margin-bottom:18px;display:flex;align-items:center;justify-content:space-between;\n    flex-wrap:wrap;gap:10px;font-size:13.5px;font-weight:600;color:var(--primary-dark);\n  }\n  .ndis-guide-page{\n    background:var(--card);border:1px solid var(--border);border-radius:16px;\n    padding:32px 48px;font-size:14px;line-height:1.65;color:var(--ink);max-width:1180px;margin:0 auto;\n  }\n  .ndis-guide-page h4{font-family:'Fraunces',serif;font-size:16.5px;margin:26px 0 10px;color:var(--primary-dark);}\n  .ndis-guide-page h4:first-of-type{margin-top:0;}\n  .ndis-guide-page p{margin:0 0 12px;}\n  .ndis-guide-page strong{color:var(--ink);}\n  .search-box{\n    flex:1;min-width:200px;position:relative;\n  }\n  .search-box input{\n    width:100%;padding:11px 14px 11px 38px;border-radius:10px;border:1px solid var(--border);\n    background:#FAFBFC;font-family:'Inter';font-size:14.5px;color:var(--ink);\n    transition:border-color .15s ease, background .15s ease;\n  }\n  .search-box input:focus{outline:none;border-color:var(--primary);background:#fff;box-shadow:0 0 0 3px var(--primary-light);}\n  .search-box svg{position:absolute;left:12px;top:50%;transform:translateY(-50%);color:var(--muted);}\n\n  .toolbar select{\n    padding:11px 14px;border-radius:10px;border:1px solid var(--border);\n    background:#FAFBFC;font-family:'Inter';font-size:14.5px;color:var(--ink);cursor:pointer;\n  }\n  .toolbar select:focus{outline:none;border-color:var(--primary);box-shadow:0 0 0 3px var(--primary-light);}\n\n  .btn{\n    font-family:'Inter';font-weight:600;font-size:14.5px;border:none;border-radius:100px;\n    padding:11px 20px;cursor:pointer;transition:transform .08s ease, background .15s ease, box-shadow .15s ease;\n  }\n  .btn:active{transform:scale(0.97);}\n  .btn-primary{background:var(--primary);color:#fff;box-shadow:0 2px 8px rgba(46,95,163,0.3);}\n  .btn-primary:hover{background:var(--primary-dark);box-shadow:0 4px 12px rgba(46,95,163,0.38);}\n  .btn-ghost{background:transparent;color:var(--primary-dark);border:1px solid var(--border);}\n  .btn-ghost:hover{background:var(--primary-light);}\n  .btn-danger-text{background:none;border:none;color:var(--danger);font-size:13px;font-weight:600;cursor:pointer;padding:4px 6px;border-radius:6px;}\n  .btn-danger-text:hover{background:#FBE9E7;}\n\n  .count-row{font-size:13px;color:var(--muted);margin-bottom:14px;padding-left:2px;}\n\n  .grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(272px,1fr));gap:18px;}\n\n  .card{\n    background:var(--card);border:1px solid var(--border);border-radius:16px;\n    padding:0;overflow:hidden;position:relative;\n    box-shadow:0 1px 3px rgba(31,42,56,0.05);\n    transition:transform .16s ease, box-shadow .16s ease;\n  }\n  .card:hover{transform:translateY(-3px);box-shadow:0 10px 24px rgba(31,42,56,0.10);}\n  .card .tags{display:flex;flex-wrap:wrap;gap:6px;padding:14px 16px 0;}\n  .product-photo{width:100%;height:170px;object-fit:contain;display:block;background:#F2F0EB;padding:8px;box-sizing:border-box;}\n  .mkt-carousel{position:relative;height:170px;background:#F2F0EB;overflow:hidden;}\n  .mkt-carousel-track{display:flex;height:100%;transition:transform .3s ease;}\n  .mkt-carousel-slide{width:100%;height:100%;flex-shrink:0;object-fit:contain;padding:8px;box-sizing:border-box;}\n  .mkt-carousel-btn{\n    position:absolute;top:50%;transform:translateY(-50%);background:rgba(31,42,56,0.55);color:#fff;\n    border:none;width:28px;height:28px;border-radius:50%;font-size:16px;line-height:1;cursor:pointer;\n    display:flex;align-items:center;justify-content:center;\n  }\n  .mkt-carousel-btn:hover{background:rgba(31,42,56,0.8);}\n  .mkt-carousel-prev{left:8px;}\n  .mkt-carousel-next{right:8px;}\n  .mkt-carousel-dots{position:absolute;bottom:8px;left:0;right:0;display:flex;justify-content:center;gap:5px;}\n  .mkt-carousel-dot{width:6px;height:6px;border-radius:50%;background:rgba(31,42,56,0.3);}\n  .mkt-carousel-dot.active{background:var(--primary);width:16px;border-radius:3px;}\n  .card .tag{\n    display:inline-flex;align-items:center;gap:5px;\n    padding:5px 11px;font-family:'JetBrains Mono',monospace;font-size:10px;\n    letter-spacing:.06em;text-transform:uppercase;font-weight:600;color:#fff;border-radius:100px;\n  }\n  .card .tag .dot{width:5px;height:5px;border-radius:50%;background:rgba(255,255,255,0.85);flex-shrink:0;}\n  .card .body{padding:16px 18px 18px;}\n  .card h3{font-size:18px;margin:0 0 5px;font-weight:600;color:var(--ink);}\n  .stars{color:var(--accent);font-size:14px;letter-spacing:1px;margin-bottom:6px;}\n  .reviews-link{\n    display:block;background:none;border:none;padding:0;margin-bottom:10px;\n    font-size:12.5px;color:var(--primary-dark);font-weight:600;cursor:pointer;text-align:left;\n  }\n  .reviews-link:hover{text-decoration:underline;}\n  .stars .empty{color:var(--border);}\n  .field-row{display:flex;gap:8px;font-size:13.5px;color:var(--ink);margin-bottom:6px;align-items:flex-start;}\n  .field-row svg{flex-shrink:0;margin-top:2px;color:var(--muted);}\n  .field-row a{color:var(--primary-dark);text-decoration:none;}\n  .field-row a:hover{text-decoration:underline;}\n  .notes{margin-top:10px;font-size:13px;color:var(--muted);line-height:1.55;border-top:1px dashed var(--border);padding-top:10px;white-space:pre-line;}\n  .referred{margin-top:9px;font-size:12px;color:var(--primary-dark);background:var(--primary-light);display:inline-block;padding:4px 10px;border-radius:100px;font-weight:500;}\n  .card-actions{display:flex;justify-content:flex-end;gap:6px;margin-top:14px;}\n  .btn-edit{background:none;border:none;color:var(--primary-dark);font-size:13px;font-weight:600;cursor:pointer;padding:4px 8px;border-radius:6px;}\n  .btn-edit:hover{background:var(--primary-light);}\n\n  .empty-state{\n    text-align:center;padding:64px 20px;color:var(--muted);\n  }\n  .empty-state svg{margin-bottom:14px;color:var(--border);}\n  .empty-state .display{font-size:21px;color:var(--primary-dark);margin-bottom:6px;}\n\n  /* Modal */\n  .overlay{\n    position:fixed;inset:0;background:rgba(31,42,56,0.5);display:none;\n    align-items:flex-start;justify-content:center;padding:40px 16px;overflow-y:auto;z-index:9999;\n    backdrop-filter:blur(2px);\n  }\n  .overlay.open{display:flex;}\n  .modal{\n    background:var(--card);border-radius:20px;padding:0;max-width:480px;width:100%;\n    box-shadow:0 24px 60px rgba(0,0,0,0.22);overflow:hidden;\n  }\n  .modal-head{\n    padding:22px 26px;background:linear-gradient(120deg, var(--primary) 0%, #3E6FB8 100%);position:relative;overflow:hidden;\n  }\n  .modal-head::before{\n    content:\"\";position:absolute;inset:0;opacity:.14;\n    background-image:radial-gradient(#fff 2px, transparent 2px);background-size:20px 20px;\n  }\n  .modal h2{font-size:21px;margin:0;color:#fff;position:relative;}\n  .modal-body{padding:24px 26px 26px;}\n  .form-grid{display:grid;gap:14px;}\n  .form-group label{display:block;font-size:12.5px;font-weight:600;color:var(--muted);margin-bottom:5px;text-transform:uppercase;letter-spacing:.04em;}\n  .form-group input,.form-group select,.form-group textarea{\n    width:100%;padding:10px 12px;border-radius:9px;border:1px solid var(--border);\n    font-family:'Inter';font-size:14.5px;color:var(--ink);background:#FAFBFC;\n    transition:border-color .15s ease;\n  }\n  .form-group input:focus,.form-group select:focus,.form-group textarea:focus{outline:none;border-color:var(--primary);box-shadow:0 0 0 3px var(--primary-light);}\n  .form-group textarea{resize:vertical;min-height:60px;}\n  .two-col{display:grid;grid-template-columns:1fr 1fr;gap:12px;}\n  .ndis-check{\n    display:flex !important;align-items:center;gap:9px;text-transform:none !important;\n    font-size:14px !important;font-weight:500 !important;color:var(--ink) !important;\n    letter-spacing:0 !important;cursor:pointer;background:var(--primary-light);\n    padding:10px 14px;border-radius:9px;border:1px solid var(--border);\n  }\n  .ndis-check input{width:auto !important;accent-color:var(--primary);}\n  .ndis-badge{\n    display:inline-flex;align-items:center;gap:5px;margin-top:9px;margin-left:6px;\n    font-size:12px;font-weight:600;color:var(--primary-dark);background:var(--primary-light);\n    padding:4px 10px;border-radius:100px;\n  }\n  .child-row{display:flex;gap:8px;margin-bottom:8px;align-items:center;}\n  .photo-status{font-size:13px;color:var(--muted);margin-top:5px;min-height:15px;font-weight:500;}\n  .photo-status.uploading{color:var(--primary-dark);background:var(--primary-light);padding:6px 10px;border-radius:8px;display:inline-block;}\n  .photo-status.done{color:#3D7A3D;}\n  .photo-status.error{color:var(--danger);}\n  .mk-photo-slot{\n    border:1px solid var(--border);border-radius:10px;padding:10px;margin-bottom:8px;\n    display:flex;flex-direction:column;gap:6px;position:relative;\n  }\n  .mk-photo-slot .remove-photo-slot{\n    position:absolute;top:8px;right:8px;background:none;border:none;color:var(--danger);\n    font-size:18px;line-height:1;cursor:pointer;padding:2px 6px;\n  }\n  .mk-photo-slot .photo-preview{max-height:110px;}\n  .photo-preview{max-height:130px;max-width:100%;border-radius:10px;margin-top:8px;display:block;object-fit:cover;}\n  .address-suggestions{\n    position:absolute;top:100%;left:0;right:0;z-index:20;\n    background:#fff;border:1px solid var(--border);border-radius:10px;\n    margin-top:4px;box-shadow:0 8px 24px rgba(31,42,56,0.12);\n    max-height:220px;overflow-y:auto;display:none;\n  }\n  .address-suggestions.open{display:block;}\n  .address-suggestion{\n    padding:10px 14px;font-size:13.5px;cursor:pointer;border-bottom:1px solid var(--border);\n  }\n  .address-suggestion:last-child{border-bottom:none;}\n  .address-suggestion:hover, .address-suggestion.active{background:var(--primary-light);}\n  .address-suggestion .loading-text{color:var(--muted);font-style:italic;cursor:default;}\n  .child-row input{flex:1;}\n  .child-row input[type=\"date\"]{flex:0 0 150px;}\n  .remove-child{background:none;border:none;color:var(--danger);font-size:20px;line-height:1;cursor:pointer;padding:0 4px;flex-shrink:0;}\n  .kids-line{font-size:13.5px;color:var(--ink);margin-bottom:6px;}\n  .kids-line b{font-weight:600;}\n  #familiesMap{height:380px;border-radius:14px;border:1px solid var(--border);margin-bottom:18px;overflow:hidden;display:none;}\n  #familiesMap.open{display:block;}\n  .family-pin{background:none;border:none;filter:drop-shadow(0 2px 3px rgba(31,42,56,0.3));}\n  .leaflet-popup-content{font-family:'Inter',sans-serif;font-size:13px;}\n  .leaflet-popup-content-wrapper{border-radius:12px;}\n  .leaflet-control-attribution{font-size:10px;}\n  .privacy-note{font-size:12.5px;color:var(--muted);background:var(--accent-light);border:1px solid #F0DDB0;padding:10px 14px;border-radius:10px;margin-bottom:16px;line-height:1.5;}\n  .chip-select{display:flex;flex-wrap:wrap;gap:7px;max-height:170px;overflow-y:auto;padding:3px 2px;}\n  .chip{\n    padding:7px 13px;border-radius:100px;border:1px solid var(--border);background:#FAFBFC;\n    font-size:13px;font-weight:500;color:var(--ink);cursor:pointer;user-select:none;\n    transition:background .12s ease, color .12s ease, border-color .12s ease, transform .08s ease;\n  }\n  .chip:hover{border-color:var(--primary);}\n  .chip:active{transform:scale(0.96);}\n  .chip.selected{background:var(--primary);color:#fff;border-color:var(--primary);}\n  .star-input{display:flex;gap:4px;font-size:24px;padding-top:2px;}\n  .star-input span{cursor:pointer;color:var(--border);transition:transform .1s ease;}\n  .star-input span:hover{transform:scale(1.15);}\n  .star-input span.on{color:var(--accent);}\n  .modal-actions{display:flex;justify-content:flex-end;gap:10px;margin-top:22px;}\n  .req{color:var(--accent);}\n  .error-text{color:var(--danger);font-size:13px;margin-top:-6px;}\n\n  .toast{\n    position:fixed;bottom:24px;left:50%;transform:translateX(-50%);\n    background:var(--primary-dark);color:#fff;padding:11px 22px;border-radius:100px;\n    font-size:13.5px;font-weight:500;box-shadow:0 8px 24px rgba(0,0,0,0.22);\n    opacity:0;pointer-events:none;transition:opacity .25s ease, transform .25s ease;z-index:100;\n  }\n  .toast.show{opacity:1;transform:translateX(-50%) translateY(-6px);}\n\n  .footnote{text-align:center;font-size:12px;color:var(--muted);margin-top:40px;display:flex;align-items:center;justify-content:center;gap:6px;}\n\n  @media (max-width:600px){\n    .two-col{grid-template-columns:1fr;}\n    header.top{padding:30px 22px 26px;border-radius:0 0 22px 22px;}\n    header.top h1{font-size:29px;}\n    .view-tabs{gap:5px;row-gap:8px;}\n    .view-tab{padding:7px 11px;font-size:12.5px;}\n    .view-tabs .btn{padding:7px 11px;font-size:12.5px;}\n    #contactBtn{margin-left:0;}\n    .contact-admin-group{margin-left:0 !important;}\n  }\n"],"\n"],"\n",["BODY",{},"\n",["DIV",{"class":"wrap"},"\n  ",["HEADER",{"class":"top"},"\n    ",["DIV",{"class":"header-top-row"},"\n      ",["DIV",{},"\n        ",["DIV",{"class":"eyebrow"},"T21 Community"],"\n        ",["H1",{},"DS Network"],"\n        ",["DIV",{"class":"header-title-underline"}],"\n      "],"\n    "],"\n